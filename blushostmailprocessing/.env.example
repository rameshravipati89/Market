# ── MongoDB ───────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme
MONGO_DB=maildb
MONGO_URI=mongodb://admin:changeme@mongodb:27017/maildb?authSource=admin

# ── Injector schedule ─────────────────────────────────────
# IMAP accounts are loaded from the MongoDB `credentials` collection at startup.
# Add/update accounts via: db.credentials.insertOne({...}) or Mongo shell.
INJECT_INTERVAL_SECONDS=300
IMAP_BATCH_SIZE=200
