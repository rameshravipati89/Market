# MongoDB — point to the same instance as blushostmailprocessing
# If running both projects locally, use host.containers.internal (Podman)
# or host.docker.internal (Docker) instead of localhost
MONGO_URI=mongodb://admin:BluehostMail@2024@host.containers.internal:27017/maildb?authSource=admin
MONGO_DB=maildb
PORT=4000

# AI Draft Reply — set ONE of these keys (Claude is tried first, then Groq)
ANTHROPIC_API_KEY=          # https://console.anthropic.com
GROQ_API_KEY=               # https://console.groq.com  (free tier available)
# Optional model overrides:
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# GROQ_MODEL=llama-3.1-8b-instant
